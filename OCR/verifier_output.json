    },
    {
      "step_id": 3,
      "text": "Observe 4y^2 = (2y)^2, 9 = 3^2 and 12y = 2 x 3 x (2y).",
      "latex": "4y^2 = (2y)^2, 9 = 3^2, 12y = 2 \times 3 \times (2y)",
      "confidence": 0.9
    },
    {
      "step_id": 4,
      "text": "Therefore",
      "latex": "",
      "confidence": 1.0
    },
    {
      "step_id": 5,
      "text": "4y^2 - 12y + 9 = (2y)^2 - 2 x 3 x (2y) + (3)^2",
      "latex": "4y^2 - 12y + 9 = (2y)^2 - 2 \times 3 \times (2y) + (3)^2",
      "confidence": 0.95
    },
    {
      "step_id": 6,
      "text": "= (2y - 3)^2 (required factorisation)",
      "latex": "(2y - 3)^2",
      "confidence": 0.95
    },
    {
      "step_id": 7,
      "text": "= (2y - 2)^3 (required factorisation)",
      "latex": "(2y - 2)^3",
      "confidence": 0.7
    }
